# Google Gemini API key used by the /api/chat serverless function.
# Get a free key from Google AI Studio: https://aistudio.google.com/app/apikey
#
# Local dev: copy this file to .env.local and fill in your key (.env.local is gitignored).
# Production: add GEMINI_API_KEY in Vercel > Project > Settings > Environment Variables.
GEMINI_API_KEY=your_key_here
