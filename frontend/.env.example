# Google Gemini API key used by the /api/chat serverless function.
# Get a free key from Google AI Studio: https://aistudio.google.com/app/apikey
#
# Local dev (with chat API):
#   1. Copy this file to .env.local and fill in your key (.env.local is gitignored).
#   2. From frontend/: npm run dev:vercel
#   3. Open http://localhost:3000 (Vercel proxies Vite + /api routes)
#
# Plain `npm run dev` serves the site only — /api/chat is not available.
#
# Production + vercel dev: also add GEMINI_API_KEY in
# Vercel > Project > Settings > Environment Variables (Development + Production).
GEMINI_API_KEY=your_key_here
